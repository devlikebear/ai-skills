{
  "name": "code-workflow",
  "description": "Code workflow skills for planning, implementing, reviewing, refactoring, and analyzing source code",
  "version": "0.10.5",
  "author": {
    "name": "devlikebear"
  },
  "repository": "https://github.com/devlikebear/ai-skills",
  "license": "MIT",
  "keywords": ["code-review", "refactoring", "planning", "implementation", "source-analysis"],
  "mcpServers": {
    "source-analyzer-search": {
      "command": "uvx",
      "args": [
        "--from", "git+https://github.com/devlikebear/ai-skills#subdirectory=claude-code/plugin/servers/source-analyzer-mcp",
        "source-analyzer-search"
      ],
      "env": {
        "PATH": "/opt/homebrew/bin:/usr/local/bin:/usr/bin:/bin:${PATH}"
      }
    }
  }
}
